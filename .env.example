# Copy this to .env for local development (do NOT commit the real .env).
# On Railway, set these as actual environment variables in the service settings.

# Discord bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_bot_token_here

# Command keyword users type after mentioning the bot, e.g. "@price-bot fetch OP01-016"
COMMAND_NAME=fetch

# TreasureTracker card API base URL
CARD_API_BASE_URL=https://treasuretracker-production.up.railway.app

# --- Queue ---
# Max number of price-check jobs allowed to wait in queue at once.
# Change this anytime and restart the service to take effect -- no code changes needed.
MAX_QUEUE_SIZE=5

# --- Scraping ---
MAX_SCRAPE_PAGES=5
SCRAPE_CONCURRENCY=3
PAGE_TIMEOUT_MS=30000
REQUIRE_VERIFIED_SELLER=true
HEADLESS=true

LOG_LEVEL=INFO
